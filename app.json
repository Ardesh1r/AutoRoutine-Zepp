{
  "app": {
    "appId": "com.autoroutine.zepp",
    "appName": "AutoRoutine",
    "appNameZh": "自动日程",
    "appDescription": "Lightweight offline-first smart automation engine for Amazfit watches. Create routines based on time, activity, and context without cloud dependency.",
    "appDescriptionZh": "为Amazfit手表设计的轻量级离线优先智能自动化引擎。无需云依赖，基于时间、活动和上下文创建日程。",
    "version": "1.0.0",
    "versionCode": 1,
    "permissions": [
      "device:os.notification",
      "device:os.vibrate",
      "device:os.alarm",
      "device:os.settings",
      "data:heart_rate",
      "data:steps",
      "data:sleep",
      "data:spo2",
      "data:stress",
      "data:activity",
      "data:calories"
    ],
    "targets": [
      "amazfit-active-2",
      "amazfit-t-rex-3",
      "amazfit-balance",
      "amazfit-bip-5",
      "amazfit-gts-4",
      "amazfit-gtr-4"
    ],
    "requiredApiLevel": 3,
    "minSystemVersion": "3.0.0",
    "icon": "icon.png",
    "previewIcon": "preview.png",
    "pages": [
      "pages/index",
      "pages/routine-detail",
      "pages/rule-editor",
      "pages/status"
    ],
    "defaultPage": "pages/index"
  },
  "module": {
    "pages": [
      {
        "path": "pages/index",
        "component": "pages/index"
      },
      {
        "path": "pages/routine-detail",
        "component": "pages/routine-detail"
      },
      {
        "path": "pages/rule-editor",
        "component": "pages/rule-editor"
      },
      {
        "path": "pages/status",
        "component": "pages/status"
      }
    ],
    "workers": [
      {
        "path": "workers/rule-engine",
        "name": "ruleEngine"
      }
    ]
  }
}
